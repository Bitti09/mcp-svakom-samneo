{
  "name": "@bitti09/mcp-svakom-samneo",
  "version": "1.1.0",
  "description": "MCP server for Svakom Sam Neo device control via Buttplug.io",
  "main": "build/index.js",
  "bin": {
    "svakom-samneo": "./build/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "prepare": "pnpm run build",
    "start": "node build/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "mcp",
    "buttplug",
    "svakom",
    "samneo",
    "teledildonics"
  ],
  "author": "Kyure_A",
  "license": "GPL",
  "packageManager": "pnpm@10.9.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "buttplug": "^4.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.4",
    "prettier": "^3.8.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
